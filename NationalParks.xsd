<xsd:schema targetNamespace="http://venus.sod.asu.edu/WSRepository/xml" 
    elementFormDefault="qualified" attributeFormDefault="unqualified">
    <xsd:annotation>
        <xsd:documentation xml:lang="en">
            National Parks 
        </xsd:documentation>
    </xsd:annotation>
    <xsd:element name="NationalParks" type="NationalParkType"/>
        <xsd:complexType name="NationalParkType">
            <xsd:sequence>
                <xsd:element name="NationalPark" type="NationalParkDetails" minOccurs="1" 
                maxOccurs="unbounded"/>
            <xsd:sequence>
        <xsd:complexType>
        <xsd:complexType name="NationalParkDetails"> 
            <xsd:sequence>
                <xsd:element name="Name" type="xs:string" minOccurs="1"/>
                <xsd:element name="Phone" type="xs:string" minOccurs="1" maxOccurs="unbounded"/>
                <xsd:element name="Address" type="AddressDetails" minOccurs="1"/>
            <xsd:sequence>      
            <xsd:attribute name="Rating" type="xs:string" use="optional"/>                    
        <xsd:complexType>
        <xsd:complexType name="AddressDetails">
            <xsd:sequence>
                <xsd:element name="Number" type="xs:string" minOccurs="1"/>
                <xsd:element name="Street" type="xs:string" minOccurs="1"/>
                <xsd:element name="City" type="xs:string" minOccurs="1"/>
                <xsd:element name="State" type="xs:string" minOccurs="1"/>
                <xsd:element name="Zip" type="xs:int" minOccurs="1"/>
            </xsd:sequence>
            <xsd:attribute name="NearestAirport" type="xs:string" use="required"/>
        </xsd:complexType>
</xsd:schema>

